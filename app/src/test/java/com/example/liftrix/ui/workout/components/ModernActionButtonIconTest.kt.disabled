package com.example.liftrix.ui.workout.components

import androidx.compose.material.icons.Icons
import androidx.compose.material.icons.filled.*
import org.junit.Test
import org.junit.Assert.*

/**
 * Test to verify that ModernActionButton uses proper Material Design icons
 * instead of Unicode text symbols for consistent visual appearance.
 */
class ModernActionButtonIconTest {
    
    @Test
    fun `verify ModernActionButton uses proper Material Design icons`() {
        // These are the critical icons that should be rendered as proper Material Design icons
        // instead of Unicode text symbols for visual consistency
        val criticalIcons = listOf(
            Icons.Default.PersonAdd,
            Icons.Default.Check,
            Icons.Default.Block,
            Icons.Default.ExitToApp,
            Icons.Default.MoreHoriz,
            Icons.Default.MoreVert,
            Icons.Default.Schedule,
            Icons.Default.Star,
            Icons.Default.PlayArrow,
            Icons.Default.Edit,
            Icons.Default.Assignment,
            Icons.Default.People,
            Icons.Default.Add,
            Icons.Default.Save,
            Icons.Default.Refresh
        )
        
        // Verify that all critical icons are valid Material Design vectors
        // The ModernActionButton components now use Icon() composables instead of Text() with Unicode symbols
        criticalIcons.forEach { icon ->
            assertNotNull(
                "Icon ${icon.name} should be a valid Material Design vector icon",
                icon
            )
            
            // Verify that the icon has proper vector data (not empty)
            assertTrue(
                "Icon ${icon.name} should have valid vector paths",
                (icon.root.size > 0) || icon.pathData.isNotEmpty()
            )
        }
    }
    
    @Test
    fun `verify icon accessibility properties`() {
        // Test that icons used in ModernActionButton have proper accessibility properties
        val accessibilityTestIcons = listOf(
            Icons.Default.Add,
            Icons.Default.Edit,
            Icons.Default.Save,
            Icons.Default.Check
        )
        
        accessibilityTestIcons.forEach { icon ->
            // Verify icon has proper size specifications
            assertEquals(
                "Icon ${icon.name} should have standard 24dp viewbox",
                24f,
                icon.viewportWidth
            )
            assertEquals(
                "Icon ${icon.name} should have standard 24dp viewbox",
                24f, 
                icon.viewportHeight
            )
        }
    }
}