package com.example.liftrix.sync

import android.content.Context
import androidx.hilt.work.HiltWorkerFactory
import androidx.test.core.app.ApplicationProvider
import androidx.test.ext.junit.runners.AndroidJUnit4
import androidx.work.*
import androidx.work.testing.SynchronousExecutor
import androidx.work.testing.WorkManagerTestInitHelper
import com.example.liftrix.LiftrixApp
import dagger.hilt.android.testing.HiltAndroidRule
import dagger.hilt.android.testing.HiltAndroidTest
import kotlinx.coroutines.runBlocking
import org.junit.Assert.*
import org.junit.Before
import org.junit.Rule
import org.junit.Test
import org.junit.runner.RunWith
import timber.log.Timber
import javax.inject.Inject

/**
 * Integration test to verify UserPublicSyncWorker can be instantiated correctly
 * without NoSuchMethodException using Hilt dependency injection.
 * 
 * This test ensures that:
 * 1. HiltWorkerFactory can create UserPublicSyncWorker instances
 * 2. @AssistedInject constructor works properly
 * 3. ProGuard/R8 rules preserve assisted factories
 */
@HiltAndroidTest
@RunWith(AndroidJUnit4::class)
class UserPublicSyncWorkerInstantiationTest {

    @get:Rule
    val hiltRule = HiltAndroidRule(this)

    @Inject
    lateinit var workerFactory: HiltWorkerFactory

    private lateinit var context: Context
    private lateinit var workManager: WorkManager

    @Before
    fun setUp() {
        hiltRule.inject()
        context = ApplicationProvider.getApplicationContext()
        
        // Initialize WorkManager with HiltWorkerFactory for testing
        val config = Configuration.Builder()
            .setWorkerFactory(workerFactory)
            .setExecutor(SynchronousExecutor())
            .build()
        
        WorkManagerTestInitHelper.initializeTestWorkManager(context, config)
        workManager = WorkManager.getInstance(context)
        
        // Suppress logs during testing
        Timber.plant(object : Timber.Tree() {
            override fun log(priority: Int, tag: String?, message: String, t: Throwable?) {
                // No-op for tests
            }
        })
    }

    @Test
    fun testUserPublicSyncWorkerCanBeInstantiated() {
        // Given: A test user ID
        val testUserId = "test-user-123"
        
        // When: We create a work request for UserPublicSyncWorker
        val workRequest = UserPublicSyncWorker.createWorkRequest(
            userId = testUserId,
            forceSync = true
        )
        
        // Then: The work request should be created successfully
        assertNotNull("Work request should not be null", workRequest)
        assertEquals("Work request should be for UserPublicSyncWorker", 
            UserPublicSyncWorker::class.java, workRequest.workSpec.workerClassName)
        
        // Verify input data is set correctly
        val inputData = workRequest.workSpec.input
        assertEquals("UserId should be set correctly", testUserId, inputData.getString("userId"))
        assertTrue("ForceSync should be true", inputData.getBoolean("forceSync", false))
        
        // And: Worker should have correct tags
        assertTrue("Work should have correct tag", workRequest.tags.contains("user_public_sync"))
    }

    @Test
    fun testWorkerFactoryCanCreateUserPublicSyncWorker() {
        // Given: Worker parameters for UserPublicSyncWorker
        val testUserId = "test-user-456"
        val inputData = Data.Builder()
            .putString("userId", testUserId)
            .putBoolean("forceSync", true)
            .build()
        
        // When: We try to create worker using HiltWorkerFactory
        val workerParams = WorkerParameters(
            java.util.UUID.randomUUID(),
            inputData,
            emptyList(),
            WorkerParameters.RuntimeExtras(),
            1,
            1,
            SynchronousExecutor(),
            TestWorkerConfiguration(),
            TestForegroundUpdater(),
            TestProgressUpdater()
        )
        
        val worker = workerFactory.createWorker(
            context,
            UserPublicSyncWorker::class.java.name,
            workerParams
        )
        
        // Then: Worker should be created successfully without NoSuchMethodException
        assertNotNull("Worker should not be null", worker)
        assertTrue("Worker should be instance of UserPublicSyncWorker", 
            worker is UserPublicSyncWorker)
        
        Timber.d("✅ UserPublicSyncWorker instantiated successfully via HiltWorkerFactory")
    }

    @Test
    fun testEnqueueWorkerDoesNotThrowException() = runBlocking {
        // Given: A work request for UserPublicSyncWorker
        val testUserId = "test-user-789"
        val workRequest = UserPublicSyncWorker.createWorkRequest(
            userId = testUserId,
            forceSync = true
        )
        
        // When: We enqueue the work
        val operation = workManager.enqueue(workRequest)
        
        // Then: Enqueue operation should complete successfully
        operation.await()
        assertTrue("Enqueue operation should succeed", operation.result.isDone)
        
        // And: Work should be in the correct state
        val workInfo = workManager.getWorkInfoById(workRequest.id).get()
        assertNotNull("WorkInfo should not be null", workInfo)
        
        // Note: Work might fail due to missing Firebase auth in test environment,
        // but the important thing is that it doesn't fail with NoSuchMethodException
        val state = workInfo.state
        assertTrue("Work should not fail with instantiation error", 
            state == WorkInfo.State.SUCCEEDED || 
            state == WorkInfo.State.FAILED || 
            state == WorkInfo.State.RUNNING ||
            state == WorkInfo.State.ENQUEUED)
        
        // If it failed, ensure it's not due to instantiation issues
        if (state == WorkInfo.State.FAILED) {
            val errorMessage = workInfo.outputData.getString("error_message") ?: ""
            assertFalse("Should not fail with NoSuchMethodException", 
                errorMessage.contains("NoSuchMethodException"))
            assertFalse("Should not fail with constructor issues", 
                errorMessage.contains("constructor"))
            
            Timber.d("✅ Worker failed for expected reasons (auth/network), not instantiation: $errorMessage")
        } else {
            Timber.d("✅ UserPublicSyncWorker executed successfully")
        }
    }

    @Test
    fun testAssistedFactoryIsGenerated() {
        // This test verifies that the assisted factory classes are generated and not stripped by R8
        try {
            // Try to load the generated assisted factory class
            val factoryClassName = "${UserPublicSyncWorker::class.java.name}_AssistedFactory"
            val factoryClass = Class.forName(factoryClassName)
            
            assertNotNull("AssistedFactory should be generated", factoryClass)
            Timber.d("✅ Assisted factory class found: ${factoryClass.name}")
            
        } catch (e: ClassNotFoundException) {
            // This might fail in unit test environment, but should work in integration tests
            Timber.w("Assisted factory class not found - this might be expected in pure unit tests")
        }
    }

    // Test helper classes
    private class TestWorkerConfiguration : WorkerParameters.RuntimeExtras()
    
    private class TestForegroundUpdater : ForegroundUpdater {
        override fun setForegroundAsync(
            context: Context,
            id: java.util.UUID,
            foregroundInfo: ForegroundInfo
        ) = com.google.common.util.concurrent.Futures.immediateFuture(null)
    }
    
    private class TestProgressUpdater : ProgressUpdater {
        override fun updateProgress(
            context: Context,
            id: java.util.UUID,
            data: Data
        ) = com.google.common.util.concurrent.Futures.immediateFuture(null)
    }
}