package com.example.liftrix.domain.usecase.workout

import com.example.liftrix.TestDataFactory
import com.example.liftrix.domain.model.*
import com.example.liftrix.domain.model.error.LiftrixError
import com.example.liftrix.domain.model.common.LiftrixResult
import com.example.liftrix.domain.repository.workout.WorkoutRepository
import com.example.liftrix.data.local.entity.WorkoutEntity
import io.mockk.*
import io.mockk.impl.annotations.MockK
import kotlinx.coroutines.ExperimentalCoroutinesApi
import kotlinx.coroutines.test.*
import kotlinx.serialization.json.Json
import org.junit.After
import org.junit.Assert.*
import org.junit.Before
import org.junit.Test
import java.time.LocalDate

/**
 * Comprehensive test suite for GetPreviousSetDataUseCase.
 * 
 * This use case handles retrieval of previous set data for active workouts:
 * - Previous workout data querying with user scoping
 * - JSON parsing and exercise set extraction
 * - Formatted display string generation
 * - Error handling for data retrieval and parsing
 * - Caching and performance optimization
 * 
 * Test Categories:
 * - Happy Path: Successful data retrieval and formatting
 * - No Previous Data: First-time exercise scenarios
 * - JSON Parsing: Valid and invalid workout data parsing
 * - Error Handling: Database and parsing failures
 * - Performance: Large workout history handling
 * - Edge Cases: Malformed data and boundary conditions
 */
@OptIn(ExperimentalCoroutinesApi::class)
class GetPreviousSetDataUseCaseTest {

    @MockK
    private lateinit var workoutRepository: WorkoutRepository
    
    private lateinit var useCase: GetPreviousSetDataUseCase
    private val testDispatcher = StandardTestDispatcher()
    private val testScope = TestScope(testDispatcher)

    // Test Data
    private val testUserId = "user_123"
    private val testExerciseId = "bench-press-id"
    private val testSetNumber = 1
    
    // Sample workout JSON data
    private val sampleWorkoutJson = """
        [
            {
                "id": "exercise_1",
                "exerciseId": "$testExerciseId",
                "name": "Bench Press",
                "sets": [
                    {
                        "setNumber": 1,
                        "actualWeight": {"kilograms": 80.0},
                        "actualReps": 10,
                        "isCompleted": true
                    },
                    {
                        "setNumber": 2,
                        "actualWeight": {"kilograms": 82.5},
                        "actualReps": 8,
                        "isCompleted": true
                    },
                    {
                        "setNumber": 3,
                        "actualWeight": {"kilograms": 85.0},
                        "actualReps": 6,
                        "isCompleted": true
                    }
                ]
            }
        ]
    """.trimIndent()

    private val bodyweightWorkoutJson = """
        [
            {
                "id": "exercise_2",
                "exerciseId": "push-ups-id",
                "name": "Push Ups",
                "sets": [
                    {
                        "setNumber": 1,
                        "actualWeight": null,
                        "actualReps": 15,
                        "isCompleted": true
                    }
                ]
            }
        ]
    """.trimIndent()

    @Before
    fun setup() {
        MockKAnnotations.init(this)
        useCase = GetPreviousSetDataUseCase(workoutRepository)
    }
    
    @After
    fun tearDown() {
        unmockkAll()
    }

    // MARK: - Happy Path Tests

    @Test
    fun `Given previous workout data exists When invoke Then returns formatted previous set data`() = testScope.runTest {
        // Given
        val workoutEntity = createTestWorkoutEntity(
            exercisesJson = sampleWorkoutJson,
            date = LocalDate.now().minusDays(2)
        )
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(
                testUserId, 
                testExerciseId, 
                5, 
                null
            ) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        assertNotNull("Should have previous sets data", response.previousSets)
        assertEquals("Should have 3 sets", 3, response.previousSets.size)
        assertEquals("Should match workout date", LocalDate.now().minusDays(2), response.lastWorkoutDate)
        assertEquals("Should count 1 workout", 1, response.totalPreviousWorkouts)
        
        // Verify formatted display strings
        val set1 = response.previousSets[1]
        assertNotNull("Set 1 should exist", set1)
        assertEquals("Set 1 display format", "80kg x 10", set1!!.formattedDisplay)
        assertEquals("Set 1 weight", 80.0, set1.weight!!, 0.01)
        assertEquals("Set 1 reps", 10, set1.reps)
        
        val set2 = response.previousSets[2]
        assertEquals("Set 2 display format", "82.5kg x 8", set2!!.formattedDisplay)
        
        val set3 = response.previousSets[3]
        assertEquals("Set 3 display format", "85kg x 6", set3!!.formattedDisplay)
    }

    @Test
    fun `Given bodyweight exercise When invoke Then returns bodyweight format`() = testScope.runTest {
        // Given
        val workoutEntity = createTestWorkoutEntity(exercisesJson = bodyweightWorkoutJson)
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest(exerciseId = "push-ups-id")
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        val set1 = response.previousSets[1]
        assertEquals("Should format as bodyweight", "Bodyweight x 15", set1!!.formattedDisplay)
        assertNull("Weight should be null for bodyweight", set1.weight)
        assertEquals("Reps should be 15", 15, set1.reps)
    }

    @Test
    fun `Given multiple workouts exist When invoke Then returns most recent data`() = testScope.runTest {
        // Given
        val recentWorkout = createTestWorkoutEntity(
            exercisesJson = sampleWorkoutJson,
            date = LocalDate.now().minusDays(1)
        )
        val olderWorkout = createTestWorkoutEntity(
            exercisesJson = sampleWorkoutJson,
            date = LocalDate.now().minusDays(5)
        )
        
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(recentWorkout, olderWorkout))
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        assertEquals("Should use most recent workout date", LocalDate.now().minusDays(1), response.lastWorkoutDate)
        assertEquals("Should count both workouts", 2, response.totalPreviousWorkouts)
        
        // Should use data from most recent workout (first in list)
        val set1 = response.previousSets[1]
        assertEquals("Should use recent workout data", "80kg x 10", set1!!.formattedDisplay)
    }

    @Test
    fun `Given excludeWorkoutId specified When invoke Then excludes current workout`() = testScope.runTest {
        // Given
        val workoutEntity = createTestWorkoutEntity(exercisesJson = sampleWorkoutJson)
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(
                testUserId, 
                testExerciseId, 
                5, 
                "current-workout-id"
            ) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest(excludeWorkoutId = "current-workout-id")
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        
        // Verify repository was called with exclude parameter
        coVerify { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(
                testUserId,
                testExerciseId,
                5,
                "current-workout-id"
            ) 
        }
    }

    // MARK: - No Previous Data Tests

    @Test
    fun `Given no previous workouts When invoke Then returns empty response`() = testScope.runTest {
        // Given
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(emptyList())
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        assertTrue("Should have empty previous sets", response.previousSets.isEmpty())
        assertNull("Should have null last workout date", response.lastWorkoutDate)
        assertEquals("Should have 0 total workouts", 0, response.totalPreviousWorkouts)
    }

    @Test
    fun `Given exercise not found in workout When invoke Then returns empty response`() = testScope.runTest {
        // Given
        val workoutWithDifferentExercise = """
            [
                {
                    "id": "exercise_other",
                    "exerciseId": "different-exercise-id",
                    "name": "Different Exercise",
                    "sets": [{"setNumber": 1, "actualReps": 10}]
                }
            ]
        """.trimIndent()
        
        val workoutEntity = createTestWorkoutEntity(exercisesJson = workoutWithDifferentExercise)
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        assertTrue("Should have empty previous sets", response.previousSets.isEmpty())
        assertNotNull("Should have workout date", response.lastWorkoutDate)
        assertEquals("Should count the workout", 1, response.totalPreviousWorkouts)
    }

    // MARK: - JSON Parsing Tests

    @Test
    fun `Given valid JSON with incomplete sets When invoke Then includes completed sets only`() = testScope.runTest {
        // Given
        val mixedCompletionJson = """
            [
                {
                    "id": "exercise_1",
                    "exerciseId": "$testExerciseId",
                    "name": "Bench Press",
                    "sets": [
                        {
                            "setNumber": 1,
                            "actualWeight": {"kilograms": 80.0},
                            "actualReps": 10,
                            "isCompleted": true
                        },
                        {
                            "setNumber": 2,
                            "actualWeight": {"kilograms": 82.5},
                            "actualReps": 8,
                            "isCompleted": false
                        },
                        {
                            "setNumber": 3,
                            "actualWeight": {"kilograms": 85.0},
                            "actualReps": 6,
                            "isCompleted": true
                        }
                    ]
                }
            ]
        """.trimIndent()
        
        val workoutEntity = createTestWorkoutEntity(exercisesJson = mixedCompletionJson)
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        assertEquals("Should have 2 completed sets", 2, response.previousSets.size)
        assertTrue("Should include set 1", response.previousSets.containsKey(1))
        assertFalse("Should exclude incomplete set 2", response.previousSets.containsKey(2))
        assertTrue("Should include set 3", response.previousSets.containsKey(3))
    }

    @Test
    fun `Given malformed JSON When invoke Then returns database error`() = testScope.runTest {
        // Given
        val malformedJson = "{ invalid json structure"
        val workoutEntity = createTestWorkoutEntity(exercisesJson = malformedJson)
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return error", result.isError)
        val error = result.error
        assertTrue("Should be database error", error is LiftrixError.DatabaseError)
        assertEquals("Should have correct operation", "PARSE_WORKOUT_JSON", (error as LiftrixError.DatabaseError).operation)
    }

    @Test
    fun `Given JSON with missing required fields When invoke Then skips invalid entries`() = testScope.runTest {
        // Given
        val incompleteJson = """
            [
                {
                    "id": "exercise_1",
                    "exerciseId": "$testExerciseId",
                    "name": "Bench Press",
                    "sets": [
                        {
                            "setNumber": 1,
                            "actualReps": 10,
                            "isCompleted": true
                        },
                        {
                            "setNumber": 2,
                            "actualWeight": {"kilograms": 80.0},
                            "actualReps": 8,
                            "isCompleted": true
                        }
                    ]
                }
            ]
        """.trimIndent()
        
        val workoutEntity = createTestWorkoutEntity(exercisesJson = incompleteJson)
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        assertEquals("Should process valid sets", 2, response.previousSets.size)
        
        val set1 = response.previousSets[1]
        assertEquals("Set 1 should be bodyweight", "Bodyweight x 10", set1!!.formattedDisplay)
        
        val set2 = response.previousSets[2]
        assertEquals("Set 2 should have weight", "80kg x 8", set2!!.formattedDisplay)
    }

    // MARK: - Error Handling Tests

    @Test
    fun `Given repository error When invoke Then returns database error`() = testScope.runTest {
        // Given
        val databaseError = LiftrixError.DatabaseError(
            errorMessage = "Database connection failed",
            operation = "QUERY_WORKOUTS",
            table = "workouts"
        )
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Error(databaseError)
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return error", result.isError)
        assertEquals("Should propagate database error", databaseError, result.error)
    }

    @Test
    fun `Given repository throws exception When invoke Then returns mapped error`() = testScope.runTest {
        // Given
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } throws RuntimeException("Unexpected database error")
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return error", result.isError)
        val error = result.error
        assertTrue("Should be database error", error is LiftrixError.DatabaseError)
        assertEquals("Should have correct operation", "QUERY_PREVIOUS_SETS", (error as LiftrixError.DatabaseError).operation)
        assertTrue("Should contain error message", error.errorMessage.contains("Failed to retrieve previous set data"))
    }

    // MARK: - Performance Tests

    @Test
    fun `Given large workout history When invoke Then completes efficiently`() = testScope.runTest {
        // Given
        val largeWorkoutJson = createLargeWorkoutJson(50) // 50 exercises
        val workoutEntity = createTestWorkoutEntity(exercisesJson = largeWorkoutJson)
        
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest()
        
        // When
        val startTime = System.currentTimeMillis()
        val result = useCase(request)
        val endTime = System.currentTimeMillis()
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val duration = endTime - startTime
        assertTrue("Should complete quickly (<100ms)", duration < 100)
        
        val response = result.getOrThrow()
        assertEquals("Should find target exercise", 3, response.previousSets.size)
    }

    @Test
    fun `Given multiple workouts with same exercise When invoke Then processes efficiently`() = testScope.runTest {
        // Given
        val workoutEntities = (1..5).map { index ->
            createTestWorkoutEntity(
                id = "workout_$index",
                exercisesJson = sampleWorkoutJson,
                date = LocalDate.now().minusDays(index.toLong())
            )
        }
        
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(workoutEntities)
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        assertEquals("Should count all workouts", 5, response.totalPreviousWorkouts)
        assertEquals("Should use most recent data", LocalDate.now().minusDays(1), response.lastWorkoutDate)
    }

    // MARK: - Edge Cases

    @Test
    fun `Given null exercises JSON When invoke Then returns empty response`() = testScope.runTest {
        // Given
        val workoutEntity = createTestWorkoutEntity(exercisesJson = null)
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        assertTrue("Should have empty previous sets", response.previousSets.isEmpty())
        assertNotNull("Should have workout date", response.lastWorkoutDate)
    }

    @Test
    fun `Given empty exercises JSON array When invoke Then returns empty response`() = testScope.runTest {
        // Given
        val workoutEntity = createTestWorkoutEntity(exercisesJson = "[]")
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        assertTrue("Should have empty previous sets", response.previousSets.isEmpty())
    }

    @Test
    fun `Given zero and negative weight values When invoke Then handles gracefully`() = testScope.runTest {
        // Given
        val edgeCaseJson = """
            [
                {
                    "id": "exercise_1",
                    "exerciseId": "$testExerciseId",
                    "name": "Test Exercise",
                    "sets": [
                        {
                            "setNumber": 1,
                            "actualWeight": {"kilograms": 0.0},
                            "actualReps": 10,
                            "isCompleted": true
                        },
                        {
                            "setNumber": 2,
                            "actualWeight": {"kilograms": -5.0},
                            "actualReps": 8,
                            "isCompleted": true
                        }
                    ]
                }
            ]
        """.trimIndent()
        
        val workoutEntity = createTestWorkoutEntity(exercisesJson = edgeCaseJson)
        coEvery { 
            workoutRepository.getLastCompletedWorkoutsWithExercise(any(), any(), any(), any()) 
        } returns LiftrixResult.Success(listOf(workoutEntity))
        
        val request = createTestRequest()
        
        // When
        val result = useCase(request)
        
        // Then
        assertTrue("Should return success", result.isSuccess)
        val response = result.getOrThrow()
        
        val set1 = response.previousSets[1]
        assertEquals("Zero weight should show as bodyweight", "Bodyweight x 10", set1!!.formattedDisplay)
        
        val set2 = response.previousSets[2]
        assertEquals("Negative weight should show as bodyweight", "Bodyweight x 8", set2!!.formattedDisplay)
    }

    // MARK: - Helper Methods

    private fun createTestRequest(
        userId: String = testUserId,
        exerciseId: String = testExerciseId,
        setNumber: Int = testSetNumber,
        excludeWorkoutId: String? = null
    ): PreviousSetDataRequest {
        return PreviousSetDataRequest(
            userId = userId,
            exerciseId = exerciseId,
            setNumber = setNumber,
            excludeWorkoutId = excludeWorkoutId
        )
    }

    private fun createTestWorkoutEntity(
        id: String = "workout_123",
        exercisesJson: String?,
        date: LocalDate = LocalDate.now().minusDays(1)
    ): WorkoutEntity {
        return WorkoutEntity(
            id = id,
            userId = testUserId,
            name = "Test Workout",
            date = date,
            status = "COMPLETED",
            exercisesJson = exercisesJson,
            startTime = null,
            endTime = null,
            duration = null,
            notes = null,
            templateId = null,
            isSynced = true,
            syncVersion = 1L,
            lastModified = System.currentTimeMillis(),
            createdAt = System.currentTimeMillis(),
            updatedAt = System.currentTimeMillis()
        )
    }

    private fun createLargeWorkoutJson(exerciseCount: Int): String {
        val exercises = (1..exerciseCount).map { index ->
            """
                {
                    "id": "exercise_$index",
                    "exerciseId": "${if (index == 1) testExerciseId else "exercise-$index"}",
                    "name": "Exercise $index",
                    "sets": [
                        {
                            "setNumber": 1,
                            "actualWeight": {"kilograms": ${70.0 + index}},
                            "actualReps": ${8 + index % 3},
                            "isCompleted": true
                        },
                        {
                            "setNumber": 2,
                            "actualWeight": {"kilograms": ${72.0 + index}},
                            "actualReps": ${7 + index % 3},
                            "isCompleted": true
                        },
                        {
                            "setNumber": 3,
                            "actualWeight": {"kilograms": ${75.0 + index}},
                            "actualReps": ${6 + index % 3},
                            "isCompleted": true
                        }
                    ]
                }
            """.trimIndent()
        }.joinToString(",\n")
        
        return "[\n$exercises\n]"
    }
}