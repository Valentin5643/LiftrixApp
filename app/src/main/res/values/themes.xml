<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.Liftrix" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryDark">@color/primary_variant</item>
        <item name="colorAccent">@color/coral_accent</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/on_background</item>
        <item name="android:textColorSecondary">@color/on_surface</item>
    </style>

    <!-- Custom text appearances -->
    <style name="TextAppearance.Liftrix.HeadlineLarge" parent="TextAppearance.AppCompat.Headline">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Liftrix.BodyLarge" parent="TextAppearance.AppCompat.Body1">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Liftrix.LabelMedium" parent="TextAppearance.AppCompat.Caption">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>