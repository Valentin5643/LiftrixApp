<?xml version="1.0" encoding="utf-8"?>
<!-- 
Security-hardened backup rules for Liftrix Android
Excludes sensitive data from device backups
-->
<full-backup-content>
    <!-- Fail closed: authenticated and encrypted app state is never backed up. -->
    <exclude domain="database" path="."/>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="file" path="."/>
    <exclude domain="external" path="."/>
</full-backup-content>
