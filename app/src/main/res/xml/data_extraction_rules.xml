<?xml version="1.0" encoding="utf-8"?>
<!--
   Security-hardened data extraction rules for Liftrix Android
   Prevents sensitive data from being included in cloud backups or device transfers
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude ALL sensitive data from cloud backup for maximum security -->
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="cache" path="."/>
        <exclude domain="external" path="."/>
        <exclude domain="root" path="."/>
        
        <!-- Only allow non-sensitive app preferences -->
        <include domain="sharedpref" path="androidx.preference"/>
        <exclude domain="sharedpref" path="firebase"/>
        <exclude domain="sharedpref" path="auth"/>
        <exclude domain="sharedpref" path="encrypted"/>
    </cloud-backup>
    
    <device-transfer>
        <!-- Restrict device-to-device transfer for security -->
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="cache" path="."/>
        <exclude domain="external" path="."/>
        <exclude domain="root" path="."/>
        
        <!-- Only allow basic app preferences -->
        <include domain="sharedpref" path="androidx.preference"/>
        <exclude domain="sharedpref" path="firebase"/>
        <exclude domain="sharedpref" path="auth"/>
        <exclude domain="sharedpref" path="encrypted"/>
    </device-transfer>
</data-extraction-rules>