{
  "name": "liftrix-billing-automation",
  "version": "1.0.0",
  "description": "Billing automation and testing tools for Liftrix Firebase project",
  "scripts": {
    "test-budget": "node test-budget-alert.js --run-test",
    "check-logs": "gcloud functions logs read enforceBudget --region=us-central1 --limit=50",
    "check-billing": "gcloud billing projects describe liftrix-390cf",
    "re-enable-billing": "node re-enable-billing.js"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.0.0",
    "googleapis": "^126.0.1"
  }
}