# Liftrix Android - Environment Variables Template
# Copy this file to .env.local (not tracked by git) and set your values

# App Signing Configuration (REQUIRED for release builds)
KEYSTORE_PATH=/secure/path/to/release.keystore
KEYSTORE_BASE64=base64_encoded_keystore_for_ci_only
KEYSTORE_PASSWORD=your_keystore_password_here
KEY_PASSWORD=your_key_password_here
KEY_ALIAS=liftrix
RELEASE_CERT_SHA256=canonical_certificate_digest_from_release_owner

# Release preflight (nonsecret; CI default is 20 GiB)
MIN_RELEASE_FREE_DISK_GIB=20

# Firebase Android Configuration (REQUIRED for clean CI release builds)
GOOGLE_SERVICES_JSON_BASE64=base64_encoded_google_services_json_for_ci_only

# Firebase OAuth Configuration (REQUIRED)
GOOGLE_CLIENT_ID_DEBUG=your_debug_google_client_id
GOOGLE_CLIENT_ID_RELEASE=your_release_google_client_id

# Security Notes:
# - Never commit actual credentials to version control
# - Store these values securely in your CI/CD environment
# - Rotate credentials regularly
# - Use different values for debug/release builds
