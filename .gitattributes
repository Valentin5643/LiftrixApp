# Auto detect text files and perform LF normalization
* text=auto

# Source code - always use LF
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Scripts - always use LF
*.sh text eol=lf
gradlew text eol=lf

# Windows scripts - always use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
gradlew.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
*.jar binary
*.so binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# IDE files
*.iml text eol=lf
.idea/** text eol=lf

# Gradle wrapper
gradle/wrapper/gradle-wrapper.jar binary
gradle/wrapper/gradle-wrapper.properties text eol=lf
