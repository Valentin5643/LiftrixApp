rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for common checks
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserId() {
      return request.auth.uid;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && getUserId() == userId;
    }
    
    function isPremiumUser() {
      return isAuthenticated() && 
             request.auth.token.premium == true;
    }
    
    function isValidEmail() {
      return isAuthenticated() && 
        (request.auth.token.firebase.sign_in_provider == 'anonymous' || 
         request.auth.token.email_verified == true);
    }
    
    function isNewDocument() {
      return resource == null;
    }
    
    function isDocumentOwner() {
      return isAuthenticated() && 
             resource.data.userId == getUserId();
    }
    
    function isRequestDataOwner() {
      return isAuthenticated() && 
             request.resource.data.userId == getUserId();
    }
    
    // Global deny rule - require authentication for all documents
    match /{document=**} {
      allow read, write: if false;
    }
    
    // User presence tracking rules
    match /user_presence/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to read presence of their friends
    match /user_presence/{userId} {
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/friends/$(request.auth.uid + '_' + userId)) ||
        exists(/databases/$(database)/documents/friends/$(userId + '_' + request.auth.uid));
    }
    
    // Users collection - personal profile management
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if isOwner(userId);
      
      // Allow creation of own profile during signup
      allow create: if isOwner(userId) && isValidEmail() &&
                   validateUserProfile(request.resource.data);
    }

    // User profiles collection - onboarding and personalization data
    match /user_profiles/{userId} {
      // Users can read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow creation of own profile during onboarding
      allow create: if isOwner(userId) && 
                   validateUserProfileData(request.resource.data);
      
      // Update own profile data
      allow update: if isOwner(userId) && 
                   validateUserProfileData(request.resource.data);
      
      // Delete own profile
      allow delete: if isOwner(userId);
    }

    // Workouts collection - personal workout data
    match /workouts/{workoutId} {
      // Read own workouts
      allow read, write: if request.auth != null && 
        resource.data.user_id == request.auth.uid;
      
      // Create new workout (must include userId)
      allow create: if isRequestDataOwner() && 
                   validateWorkoutData(request.resource.data);
      
      // Update own workout
      allow update: if isDocumentOwner() && 
                   isRequestDataOwner() &&
                   validateWorkoutData(request.resource.data);
      
      // Delete own workout
      allow delete: if isDocumentOwner();
    }
    
    // Personal Records (PRs) collection - achievement tracking
    match /prs/{prId} {
      // Read own PRs
      allow read: if isDocumentOwner();
      
      // Create new PR (must include userId)
      allow create: if isRequestDataOwner() && 
                   validatePRData(request.resource.data);
      
      // Update own PR
      allow update: if isDocumentOwner() && 
                   isRequestDataOwner() &&
                   validatePRData(request.resource.data);
      
      // Delete own PR
      allow delete: if isDocumentOwner();
    }
    
    // Friendships collection - social features
    match /friendships/{friendshipId} {
      // Read friendships where user is either sender or receiver
      allow read: if isAuthenticated() && 
                 (resource.data.senderId == getUserId() || 
                  resource.data.receiverId == getUserId());
      
      // Create friendship requests (must be the sender)
      allow create: if isAuthenticated() && 
                   request.resource.data.senderId == getUserId() &&
                   validateFriendshipData(request.resource.data);
      
      // Update friendship status (must be the receiver to accept/decline)
      allow update: if isAuthenticated() && 
                   resource.data.receiverId == getUserId() &&
                   validateFriendshipUpdate(resource.data, request.resource.data);
      
      // Delete friendship (either party can delete)
      allow delete: if isAuthenticated() && 
                   (resource.data.senderId == getUserId() || 
                    resource.data.receiverId == getUserId());
    }
    
    // Friends relationships
    match /friends/{friendshipId} {
      allow read, write: if request.auth != null && 
        (friendshipId.split('_')[0] == request.auth.uid || 
         friendshipId.split('_')[1] == request.auth.uid);
    }
    
    // Social Discovery Features
    
    // Users public collection - public profile data for social discovery
    match /users_public/{userId} {
      // Anyone authenticated can read public profiles
      allow read: if isAuthenticated();
      
      // Users can only write their own public profile
      allow write: if isOwner(userId) && 
                   validatePublicProfileData(request.resource.data);
    }
    
    // User search cache - cached search results with TTL
    match /user_search_cache/{cacheId} {
      // Users can read their own cached search results
      allow read: if isAuthenticated() && 
                 resource.data.searcherId == getUserId();
      
      // Users can write their own search cache entries
      allow write: if isAuthenticated() && 
                  request.resource.data.searcherId == getUserId() &&
                  validateSearchCacheData(request.resource.data);
      
      // Allow cleanup of expired cache entries
      allow delete: if isAuthenticated() && 
                   (resource.data.searcherId == getUserId() || 
                    resource.data.expiresAt < request.time.toMillis());
    }
    
    // QR code mappings - secure QR code to profile mappings
    match /qr_code_mappings/{qrCodeId} {
      // Anyone can read QR code mappings to resolve profiles
      allow read: if isAuthenticated();
      
      // Users can only create QR codes for their own profile
      allow create: if isAuthenticated() && 
                   request.resource.data.userId == getUserId() &&
                   validateQRCodeMappingData(request.resource.data);
      
      // Users can update their own QR codes (regenerate, disable)
      allow update: if isAuthenticated() && 
                   resource.data.userId == getUserId() &&
                   validateQRCodeMappingData(request.resource.data);
      
      // Users can delete their own QR codes
      allow delete: if isAuthenticated() && 
                   resource.data.userId == getUserId();
    }
    
    // Profile views tracking - analytics for profile interactions
    match /profile_views/{viewId} {
      // Users can read views of their own profile
      allow read: if isAuthenticated() && 
                 resource.data.profileUserId == getUserId();
      
      // Users can create view records when viewing others' profiles
      allow create: if isAuthenticated() && 
                   request.resource.data.viewerId == getUserId() &&
                   request.resource.data.profileUserId != getUserId() &&
                   validateProfileViewData(request.resource.data);
      
      // No updates or deletes allowed (append-only for analytics)
      allow update, delete: if false;
    }
    
    // Connection requests - social connection management
    match /connection_requests/{requestId} {
      // Users can read requests where they are sender or receiver
      allow read: if isAuthenticated() && 
                 (resource.data.senderId == getUserId() || 
                  resource.data.receiverId == getUserId());
      
      // Users can create requests they are sending
      allow create: if isAuthenticated() && 
                   request.resource.data.senderId == getUserId() &&
                   request.resource.data.senderId != request.resource.data.receiverId &&
                   validateConnectionRequestData(request.resource.data);
      
      // Users can update requests they are receiving (accept/decline)
      allow update: if isAuthenticated() && 
                   resource.data.receiverId == getUserId() &&
                   validateConnectionRequestUpdate(resource.data, request.resource.data);
      
      // Users can delete requests they sent or received
      allow delete: if isAuthenticated() && 
                   (resource.data.senderId == getUserId() || 
                    resource.data.receiverId == getUserId());
    }
    
    // Premium features collection - subscription-based content
    match /premium_workouts/{workoutId} {
      // Premium users can read premium workout templates
      allow read: if isPremiumUser();
      
      // Only admins can create/update premium content (via Cloud Functions)
      allow write: if false;
    }
    
    match /premium_exercises/{exerciseId} {
      // Premium users can read premium exercises
      allow read: if isPremiumUser();
      
      // Only admins can create/update premium content (via Cloud Functions)
      allow write: if false;
    }
    
    // AI summaries - premium feature for workout analysis
    match /ai_summaries/{summaryId} {
      // Read own AI summaries (premium feature)
      allow read: if isPremiumUser() && isDocumentOwner();
      
      // Create AI summary request (premium feature)
      allow create: if isPremiumUser() && 
                   isRequestDataOwner() &&
                   validateAISummaryData(request.resource.data);
      
      // AI summaries are created/updated by Cloud Functions
      allow update, delete: if false;
    }
    
    // Exercise templates - community and personal templates
    match /exercise_templates/{templateId} {
      // Everyone can read public templates
      allow read: if isAuthenticated() && 
                 (resource.data.isPublic == true || isDocumentOwner());
      
      // Create personal templates
      allow create: if isRequestDataOwner() && 
                   validateExerciseTemplateData(request.resource.data);
      
      // Update own templates
      allow update: if isDocumentOwner() && 
                   isRequestDataOwner() &&
                   validateExerciseTemplateData(request.resource.data);
      
      // Delete own templates
      allow delete: if isDocumentOwner();
    }
    
    // Workout templates - personal and premium templates
    match /workout_templates/{templateId} {
      // Read public templates and own templates
      allow read: if isAuthenticated() && 
                 (resource.data.isPublic == true || 
                  isDocumentOwner() ||
                  (resource.data.isPremium == true && isPremiumUser()));
      
      // Create personal templates
      allow create: if isRequestDataOwner() && 
                   validateWorkoutTemplateData(request.resource.data);
      
      // Update own templates
      allow update: if isDocumentOwner() && 
                   isRequestDataOwner() &&
                   validateWorkoutTemplateData(request.resource.data);
      
      // Delete own templates
      allow delete: if isDocumentOwner();
    }
    
    // User settings - personal preferences and subcollections
    match /users/{userId}/settings/{settingId} {
      // Users can read and write their own settings
      allow read, write: if isOwner(userId);
      
      // Allow creation of settings documents
      allow create: if isOwner(userId) && 
                   validateUserSettingsData(request.resource.data);
      
      // Allow updates to settings documents
      allow update: if isOwner(userId) && 
                   validateUserSettingsData(request.resource.data);
      
      // Allow deletion of settings documents
      allow delete: if isOwner(userId);
    }
    
    // User settings - personal preferences (legacy support)
    match /user_settings/{userId} {
      // Users can read and write their own settings
      allow read, write: if isOwner(userId) &&
                        validateUserSettingsData(request.resource.data);
    }
    
    // Debug collection (development only - remove in production)
    match /debug/{document} {
      allow read, write: if isAuthenticated();
    }
    
    // Validation functions
    function validateUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'created_at']) &&
             data.uid is string &&
             data.email is string &&
             data.created_at is timestamp &&
             data.uid == getUserId();
    }
    
    function validateWorkoutData(data) {
      return data.keys().hasAll(['userId', 'name', 'date', 'status', 'created_at']) &&
             data.userId is string &&
             data.name is string &&
             data.date is string &&
             data.status is string &&
             data.created_at is timestamp &&
             data.exercises is list &&
             data.exercises.size() <= 50 && // Max exercises per workout
             data.name.size() <= 100; // Max workout name length
    }
    
    function validatePRData(data) {
      return data.keys().hasAll(['userId', 'exerciseName', 'weight', 'reps', 'date', 'created_at']) &&
             data.userId is string &&
             data.exerciseName is string &&
             data.weight is number &&
             data.reps is number &&
             data.date is string &&
             data.created_at is timestamp &&
             data.weight >= 0 && data.weight <= 1000 && // Reasonable weight limits (kg)
             data.reps >= 1 && data.reps <= 1000; // Reasonable rep limits
    }
    
    function validateFriendshipData(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'status', 'created_at']) &&
             data.senderId is string &&
             data.receiverId is string &&
             data.status == 'pending' &&
             data.created_at is timestamp &&
             data.senderId != data.receiverId; // Can't friend yourself
    }
    
    function validateFriendshipUpdate(oldData, newData) {
      return oldData.senderId == newData.senderId &&
             oldData.receiverId == newData.receiverId &&
             oldData.created_at == newData.created_at &&
             newData.status in ['accepted', 'declined', 'blocked'] &&
             newData.updated_at is timestamp;
    }
    
    function validateAISummaryData(data) {
      return data.keys().hasAll(['userId', 'workoutId', 'requestedAt']) &&
             data.userId is string &&
             data.workoutId is string &&
             data.requestedAt is timestamp;
    }
    
    function validateExerciseTemplateData(data) {
      return data.keys().hasAll(['userId', 'name', 'category', 'isPublic', 'created_at']) &&
             data.userId is string &&
             data.name is string &&
             data.category is string &&
             data.isPublic is bool &&
             data.created_at is timestamp &&
             data.name.size() <= 100; // Max exercise name length
    }
    
    function validateWorkoutTemplateData(data) {
      return data.keys().hasAll(['userId', 'name', 'isPublic', 'created_at']) &&
             data.userId is string &&
             data.name is string &&
             data.isPublic is bool &&
             data.created_at is timestamp &&
             data.exercises is list &&
             data.exercises.size() <= 20 && // Max exercises per template
             data.name.size() <= 100; // Max template name length
    }
    
    function validateUserSettingsData(data) {
      return data.keys().hasAll(['userId', 'updatedAt']) &&
             data.userId is string &&
             data.updatedAt is number &&
             data.userId == getUserId() &&
             // Dark mode validation if present
             (!(data.keys().hasAny(['darkMode'])) || 
              data.darkMode is bool) &&
             // Notifications validation if present
             (!(data.keys().hasAny(['notificationsEnabled'])) || 
              data.notificationsEnabled is bool) &&
             // Sync timestamp validation if present
             (!(data.keys().hasAny(['syncedAt'])) || 
              data.syncedAt is number);
    }
    
    function validateUserProfileData(data) {
      return data.keys().hasAll(['userId', 'updatedAt', 'profileVersion']) &&
             data.userId is string &&
             data.updatedAt is timestamp &&
             data.profileVersion is number &&
             data.userId == getUserId() &&
             // Age validation if present (13-100 years)
             (!(data.keys().hasAny(['age'])) || 
              (data.age is number && data.age >= 13 && data.age <= 100)) &&
             // Weight validation if present (positive value)
             (!(data.keys().hasAny(['weight'])) || 
              (data.weight is map && data.weight.value is number && data.weight.value >= 0 && data.weight.value <= 1000)) &&
             // Equipment validation if present (must be list)
             (!(data.keys().hasAny(['availableEquipment'])) || 
              (data.availableEquipment is list && data.availableEquipment.size() <= 20)) &&
             // Other equipment validation if present (string length limit)
             (!(data.keys().hasAny(['otherEquipment'])) || 
              (data.otherEquipment is string && data.otherEquipment.size() <= 200)) &&
             // Fitness goals validation if present (must be list)
             (!(data.keys().hasAny(['fitnessGoals'])) || 
              (data.fitnessGoals is list && data.fitnessGoals.size() <= 10)) &&
             // Goals priority validation if present (must be map)
             (!(data.keys().hasAny(['goalsPriority'])) || 
              (data.goalsPriority is map && data.goalsPriority.size() <= 10)) &&
             // Completed timestamp validation if present
             (!(data.keys().hasAny(['completedAt'])) || 
              data.completedAt is timestamp);
    }
    
    // Social Features Validation Functions
    
    function validatePublicProfileData(data) {
      return data.keys().hasAll(['userId', 'displayName', 'updatedAt']) &&
             data.userId is string &&
             data.displayName is string &&
             data.updatedAt is timestamp &&
             data.userId == getUserId() &&
             data.displayName.size() >= 2 && data.displayName.size() <= 50 &&
             // Bio validation if present
             (!(data.keys().hasAny(['bio'])) || 
              (data.bio is string && data.bio.size() <= 500)) &&
             // Profile image validation if present
             (!(data.keys().hasAny(['profileImageUrl'])) || 
              (data.profileImageUrl is string && data.profileImageUrl.size() <= 500)) &&
             // Fitness level validation if present
             (!(data.keys().hasAny(['fitnessLevel'])) || 
              data.fitnessLevel in ['BEGINNER', 'INTERMEDIATE', 'ADVANCED', 'EXPERT']) &&
             // Privacy settings validation if present
             (!(data.keys().hasAny(['privacySettings'])) || 
              (data.privacySettings is map && validatePrivacySettings(data.privacySettings))) &&
             // Equipment validation if present
             (!(data.keys().hasAny(['availableEquipment'])) || 
              (data.availableEquipment is list && data.availableEquipment.size() <= 20)) &&
             // Goals validation if present
             (!(data.keys().hasAny(['fitnessGoals'])) || 
              (data.fitnessGoals is list && data.fitnessGoals.size() <= 10));
    }
    
    function validatePrivacySettings(privacySettings) {
      return // Profile visibility validation if present
             (!(privacySettings.keys().hasAny(['profileVisibility'])) || 
              privacySettings.profileVisibility in ['PUBLIC', 'FRIENDS_ONLY', 'PRIVATE']) &&
             // Show workout stats validation if present
             (!(privacySettings.keys().hasAny(['showWorkoutStats'])) || 
              privacySettings.showWorkoutStats is bool) &&
             // Show equipment validation if present
             (!(privacySettings.keys().hasAny(['showEquipment'])) || 
              privacySettings.showEquipment is bool) &&
             // Show goals validation if present
             (!(privacySettings.keys().hasAny(['showGoals'])) || 
              privacySettings.showGoals is bool);
    }
    
    function validateSearchCacheData(data) {
      return data.keys().hasAll(['searcherId', 'searchQuery', 'results', 'createdAt', 'expiresAt']) &&
             data.searcherId is string &&
             data.searchQuery is string &&
             data.results is list &&
             data.createdAt is timestamp &&
             data.expiresAt is number &&
             data.searcherId == getUserId() &&
             data.searchQuery.size() >= 2 && data.searchQuery.size() <= 100 &&
             data.results.size() <= 50 && // Max cached results
             data.expiresAt > request.time.toMillis(); // Must be future expiration
    }
    
    function validateQRCodeMappingData(data) {
      return data.keys().hasAll(['userId', 'qrCodeData', 'createdAt']) &&
             data.userId is string &&
             data.qrCodeData is string &&
             data.createdAt is timestamp &&
             data.userId == getUserId() &&
             data.qrCodeData.size() >= 10 && data.qrCodeData.size() <= 500 &&
             // Expiration validation if present
             (!(data.keys().hasAny(['expiresAt'])) || 
              (data.expiresAt is number && data.expiresAt > request.time.toMillis())) &&
             // Usage count validation if present
             (!(data.keys().hasAny(['usageCount'])) || 
              (data.usageCount is number && data.usageCount >= 0 && data.usageCount <= 10000)) &&
             // Active status validation if present
             (!(data.keys().hasAny(['isActive'])) || 
              data.isActive is bool);
    }
    
    function validateProfileViewData(data) {
      return data.keys().hasAll(['viewerId', 'profileUserId', 'viewedAt']) &&
             data.viewerId is string &&
             data.profileUserId is string &&
             data.viewedAt is timestamp &&
             data.viewerId == getUserId() &&
             data.viewerId != data.profileUserId &&
             // View source validation if present
             (!(data.keys().hasAny(['viewSource'])) || 
              data.viewSource in ['SEARCH', 'QR_CODE', 'DIRECT_LINK', 'FRIEND_LIST']) &&
             // Metadata validation if present
             (!(data.keys().hasAny(['metadata'])) || 
              (data.metadata is map && data.metadata.keys().size() <= 10));
    }
    
    function validateConnectionRequestData(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'status', 'createdAt']) &&
             data.senderId is string &&
             data.receiverId is string &&
             data.status == 'PENDING' &&
             data.createdAt is timestamp &&
             data.senderId == getUserId() &&
             data.senderId != data.receiverId &&
             // Message validation if present
             (!(data.keys().hasAny(['message'])) || 
              (data.message is string && data.message.size() <= 500)) &&
             // Connection type validation if present
             (!(data.keys().hasAny(['connectionType'])) || 
              data.connectionType in ['FRIEND', 'WORKOUT_PARTNER', 'MENTOR']);
    }
    
    function validateConnectionRequestUpdate(oldData, newData) {
      return oldData.senderId == newData.senderId &&
             oldData.receiverId == newData.receiverId &&
             oldData.createdAt == newData.createdAt &&
             newData.status in ['ACCEPTED', 'DECLINED', 'BLOCKED'] &&
             newData.keys().hasAll(['updatedAt']) &&
             newData.updatedAt is timestamp &&
             // Response message validation if present
             (!(newData.keys().hasAny(['responseMessage'])) || 
              (newData.responseMessage is string && newData.responseMessage.size() <= 500));
    }
  }
}
