rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for common validation
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ========================================
    // SECURITY: Timestamp Validation (SEC-T006)
    // Prevents timestamp manipulation attacks (SEC-006)
    // ========================================

    /**
     * Validates that client-provided lastModified timestamp is not in the future.
     *
     * Security: Prevents attackers from setting future timestamps to force data override
     * in last-write-wins conflict resolution (SEC-006).
     *
     * Tolerance: Allows 5-minute clock skew for legitimate client time differences.
     */
    function isValidTimestamp(clientTimestamp) {
      // Accept timestamp if it's within 5 minutes of server time
      let maxAllowedTime = request.time.toMillis() + (5 * 60 * 1000); // 5 minutes tolerance
      return clientTimestamp <= maxAllowedTime;
    }

    /**
     * Validates sync metadata including timestamp verification.
     * Used for all synced entities to ensure data integrity.
     */
    function hasValidSyncTimestamp() {
      return !('lastModified' in request.resource.data) ||
             (request.resource.data.lastModified is int &&
              isValidTimestamp(request.resource.data.lastModified)) ||
             (request.resource.data.lastModified is timestamp);
    }
    
    function isValidUserProfile() {
      // Relaxed validation for UserPublicSyncWorker - only require userId
      return request.resource.data.keys().hasAll(['userId']) &&
             request.resource.data.userId == request.auth.uid &&
             // Allow all optional fields that UserPublicSyncWorker may write
             (!('username' in request.resource.data) || (request.resource.data.username is string && request.resource.data.username.size() <= 20)) &&
             (!('displayName' in request.resource.data) || (request.resource.data.displayName is string && request.resource.data.displayName.size() <= 50)) &&
             (!('bio' in request.resource.data) || request.resource.data.bio is string) &&
             (!('age' in request.resource.data) || request.resource.data.age is int) &&
             (!('fitnessLevel' in request.resource.data) || request.resource.data.fitnessLevel is string) &&
             (!('isPublic' in request.resource.data) || request.resource.data.isPublic is bool) &&
             (!('isPrivate' in request.resource.data) || request.resource.data.isPrivate is bool) &&
             (!('memberSince' in request.resource.data) || request.resource.data.memberSince is string) &&
             (!('lastActiveAt' in request.resource.data) || request.resource.data.lastActiveAt is string) &&
             (!('searchTokens' in request.resource.data) || request.resource.data.searchTokens is list) &&
             (!('searchKeywords' in request.resource.data) || request.resource.data.searchKeywords is list) &&
             (!('totalWorkouts' in request.resource.data) || request.resource.data.totalWorkouts is int) &&
             (!('currentStreak' in request.resource.data) || request.resource.data.currentStreak is int) &&
             (!('longestStreak' in request.resource.data) || request.resource.data.longestStreak is int) &&
             (!('totalWorkoutTime' in request.resource.data) || request.resource.data.totalWorkoutTime is int) &&
             (!('averageWorkoutTime' in request.resource.data) || request.resource.data.averageWorkoutTime is int) &&
             (!('followersCount' in request.resource.data) || request.resource.data.followersCount is int) &&
             (!('followingCount' in request.resource.data) || request.resource.data.followingCount is int) &&
             (!('profileImageUrl' in request.resource.data) || request.resource.data.profileImageUrl == null || request.resource.data.profileImageUrl is string) &&
             (!('coverImageUrl' in request.resource.data) || request.resource.data.coverImageUrl == null || request.resource.data.coverImageUrl is string) &&
             (!('isVerified' in request.resource.data) || request.resource.data.isVerified is bool) &&
             (!('profileViews' in request.resource.data) || request.resource.data.profileViews is int) &&
             (!('profileCompletionPercentage' in request.resource.data) || request.resource.data.profileCompletionPercentage is int) &&
             (!('fitnessGoals' in request.resource.data) || request.resource.data.fitnessGoals is list) &&
             (!('availableEquipment' in request.resource.data) || request.resource.data.availableEquipment is list) &&
             (!('publicAchievements' in request.resource.data) || request.resource.data.publicAchievements is list) &&
             (!('syncVersion' in request.resource.data) || request.resource.data.syncVersion is int) &&
             (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }
    
    function isValidBio() {
      return !('bio' in request.resource.data) || 
             (request.resource.data.bio is string && 
              request.resource.data.bio.size() <= 500);
    }
    
    function isValidAge() {
      return !('age' in request.resource.data) || 
             (request.resource.data.age is int && 
              request.resource.data.age >= 13 && 
              request.resource.data.age <= 100);
    }
    
    function isValidFitnessLevel() {
      return !('fitnessLevel' in request.resource.data) ||
             (request.resource.data.fitnessLevel is string &&
              request.resource.data.fitnessLevel.size() <= 50);
    }
    
    // ========================================
    // FIREBASE SYNC INFRASTRUCTURE RULES
    // Added by SPEC-20250118-firebase-sync-infrastructure
    // ========================================
    
    // Helper functions for sync infrastructure
    function isValidSyncMetadata() {
      return request.resource.data.keys().hasAll(['syncVersion', 'lastModified', 'isSynced']) &&
             (request.resource.data.syncVersion is int || request.resource.data.syncVersion is number) &&
             request.resource.data.syncVersion >= 0 &&
             request.resource.data.lastModified is timestamp &&
             request.resource.data.isSynced is bool;
    }
    
    // Achievement validation function
    function isValidAchievement() {
      return request.resource.data.keys().hasAll(['id', 'userId', 'type', 'title']) &&
             request.resource.data.id is string &&
             request.resource.data.userId is string &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.type is string &&
             request.resource.data.title is string &&
             request.resource.data.title.size() > 0 &&
             request.resource.data.title.size() <= 100 &&
             (!('description' in request.resource.data) || request.resource.data.description is string) &&
             (!('unlockedAt' in request.resource.data) || (request.resource.data.unlockedAt is int || request.resource.data.unlockedAt is number)) &&
             (!('isDisplayed' in request.resource.data) || request.resource.data.isDisplayed is bool) &&
             (!('syncVersion' in request.resource.data) || (request.resource.data.syncVersion is int || request.resource.data.syncVersion is number)) &&
             (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp) &&
             (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }
    
    // Users collection - user profile data with sync support
    match /users/{userId} {
      // Allow querying for public profiles (list operations for collection queries)
      allow list: if isAuthenticated();

      // Allow read if owner OR document has isPublic == true
      // Simplified condition - only docs with explicit isPublic: true are accessible
      allow get, read: if isAuthenticated() &&
                          (isOwner(userId) ||
                           (resource.data.isPublic == true));
      
      // GMAIL FIX: Simplified write rules that accept all fields Gmail authentication sends
      allow write, create: if isAuthenticated() && 
                              isOwner(userId) &&
                              request.resource.data.keys().hasAll(['userId']) &&
                              request.resource.data.userId == request.auth.uid;
    }
    
    // Workouts subcollection - user workout data
    match /users/{userId}/workouts/{workoutId} {
      // Allow read for authenticated users who own the data
      allow read: if isAuthenticated() && isOwner(userId);

      // Allow write with timestamp validation (SEC-T006)
      allow write: if isAuthenticated() &&
                      isOwner(userId) &&
                      request.resource.data.keys().hasAll(['id', 'userId']) &&
                      request.resource.data.userId == request.auth.uid &&
                      hasValidSyncTimestamp();

      allow create: if isAuthenticated() &&
                       isOwner(userId) &&
                       request.resource.data.keys().hasAll(['id', 'userId']) &&
                       request.resource.data.userId == request.auth.uid &&
                       hasValidSyncTimestamp();
    }
    
    // Templates subcollection - user workout templates
    match /users/{userId}/templates/{templateId} {
      // Allow read for owner and public templates
      allow read: if isAuthenticated() && isOwner(userId);
      allow read: if isAuthenticated() &&
                     resource.data.isPublic == true &&
                     !hasBlockRelationship(request.auth.uid, userId);

      // Allow write with timestamp validation (SEC-T006)
      allow write: if isAuthenticated() &&
                      isOwner(userId) &&
                      request.resource.data.keys().hasAll(['id', 'userId']) &&
                      request.resource.data.userId == request.auth.uid &&
                      hasValidSyncTimestamp();

      allow create: if isAuthenticated() &&
                       isOwner(userId) &&
                       request.resource.data.keys().hasAll(['id', 'userId']) &&
                       request.resource.data.userId == request.auth.uid &&
                       hasValidSyncTimestamp();
    }
    
    // Achievements subcollection - user achievements
    match /users/{userId}/achievements/{achievementId} {
      allow read: if isAuthenticated() && isOwner(userId);

      // Allow client-side achievement writes with validation and timestamp check (SEC-T006)
      allow write: if isAuthenticated() &&
                      isOwner(userId) &&
                      isValidAchievement() &&
                      hasValidSyncTimestamp();

      allow create: if isAuthenticated() &&
                       isOwner(userId) &&
                       isValidAchievement() &&
                       hasValidSyncTimestamp();
    }
    
    // Users public profiles - publicly accessible profile data
    match /users_public/{userId} {
      allow read: if isAuthenticated() &&
                     (isOwner(userId) || 
                      resource.data.isPublic == true);
                      
      // Simplified validation for UserPublicSyncWorker - only require userId
      allow write: if isAuthenticated() && 
                      isOwner(userId) &&
                      request.resource.data.keys().hasAll(['userId']) &&
                      request.resource.data.userId == request.auth.uid;
      
      allow create: if isAuthenticated() && 
                       isOwner(userId) &&
                       request.resource.data.keys().hasAll(['userId']) &&
                       request.resource.data.userId == request.auth.uid;
    }
    
    // User achievements - legacy collection for backward compatibility
    match /user_achievements/{achievementId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      
      // Allow write for achievement operations with proper validation
      allow write: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) &&
                      request.resource.data.userId == request.auth.uid;
      
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId) &&
                       request.resource.data.userId == request.auth.uid;
    }
    
    // QR code mappings for profile sharing
    match /qr_codes/{qrCodeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) &&
                      request.resource.data.keys().hasAll(['userId', 'createdAt', 'expiresAt']) &&
                      request.resource.data.userId == request.auth.uid;
    }
    
    // User search cache - publicly readable for authenticated users
    match /user_search_cache/{userId} {
      // SEARCH FIX: Allow all authenticated users to read search index for discovery
      allow read: if isAuthenticated();
      
      allow write: if isAuthenticated() && 
                      isOwner(userId) &&
                      request.resource.data.keys().hasAll(['userId']) &&
                      request.resource.data.userId == request.auth.uid;
      
      allow create: if isAuthenticated() && 
                       isOwner(userId) &&
                       request.resource.data.keys().hasAll(['userId']) &&
                       request.resource.data.userId == request.auth.uid;
    }
    
    // Connection management (for future friend system)
    match /connections/{connectionId} {
      allow read: if isAuthenticated() && 
                     (isOwner(resource.data.fromUserId) || 
                      isOwner(resource.data.toUserId));
      allow write: if isAuthenticated() && 
                      isOwner(request.resource.data.fromUserId) &&
                      request.resource.data.fromUserId == request.auth.uid;
    }
    
    // Profile image metadata
    match /profile_images/{userId} {
      allow read: if isAuthenticated() && 
                     (isOwner(userId) || 
                      get(/databases/$(database)/documents/users_public/$(userId)).data.isPublic == true);
      allow write: if isAuthenticated() && 
                      isOwner(userId) &&
                      request.resource.data.userId == request.auth.uid;
    }
    
    // Workout data - private to user
    match /workouts/{userId}/user_workouts/{workoutId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }
    
    // Exercise data - publicly readable reference data
    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow write: if false; // Exercise data is read-only
    }
    
    // ========================================
    // SOCIAL INFRASTRUCTURE SECURITY RULES
    // Added by SPEC-20250113-social-infrastructure
    // ========================================
    
    // Helper functions for social features
    function isValidSocialProfile() {
      return request.resource.data.keys().hasAll(['userId', 'username', 'createdAt', 'updatedAt']) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.username is string &&
             request.resource.data.username.size() >= 3 &&
             request.resource.data.username.size() <= 20 &&
             request.resource.data.username.matches('^[a-zA-Z0-9_]+$');
    }
    
    function isValidDisplayName() {
      return !('displayName' in request.resource.data) ||
             (request.resource.data.displayName is string &&
              request.resource.data.displayName.size() <= 50);
    }
    
    function isValidSocialBio() {
      return !('bio' in request.resource.data) ||
             (request.resource.data.bio is string &&
              request.resource.data.bio.size() <= 500);
    }
    
    function isFollower(targetUserId) {
      // Check if current user is following the target user
      return exists(/databases/$(database)/documents/follow_relationships/$(request.auth.uid + '_' + targetUserId)) &&
             get(/databases/$(database)/documents/follow_relationships/$(request.auth.uid + '_' + targetUserId)).data.status == 'ACCEPTED';
    }
    
    function isPublicProfile(userId) {
      // Check if user has a public social profile
      return exists(/databases/$(database)/documents/social_profiles/$(userId)) &&
             get(/databases/$(database)/documents/social_profiles/$(userId)).data.isPrivate == false;
    }
    
    function hasBlockRelationship(userId1, userId2) {
      // Check if there's a block relationship between two users (either direction)
      return exists(/databases/$(database)/documents/blocked_users/$(userId1 + '_' + userId2)) ||
             exists(/databases/$(database)/documents/blocked_users/$(userId2 + '_' + userId1));
    }
    
    // Social profiles - core social data
    match /social_profiles/{userId} {
      // SEARCH FIX: Allow all authenticated users to read social profiles for discovery
      allow read: if isAuthenticated();
                       
      // SEARCH FIX: Simplified validation to prevent social profile creation failures
      allow write, create: if isAuthenticated() &&
                              isOwner(userId) &&
                              request.resource.data.keys().hasAll(['userId']) &&
                              request.resource.data.userId == request.auth.uid;
    }
    
    // Follow relationships - user connections
    match /follow_relationships/{relationshipId} {
      // FIXED: Allow reads for documents where user is involved
      // This supports both individual document reads and collection queries
      allow read: if isAuthenticated() && 
                     (resource.data.followerId == request.auth.uid ||
                      resource.data.followingId == request.auth.uid);
                      
      allow create: if isAuthenticated() &&
                       isOwner(request.resource.data.followerId) &&
                       request.resource.data.followerId == request.auth.uid &&
                       relationshipId == request.resource.data.followerId + '_' + request.resource.data.followingId &&
                       request.resource.data.keys().hasAll(['followerId', 'followingId', 'status', 'createdAt']) &&
                       request.resource.data.status in ['PENDING', 'ACCEPTED', 'BLOCKED'] &&
                       !hasBlockRelationship(request.resource.data.followerId, request.resource.data.followingId);

      // Allow the followed user to accept a pending request.
      allow update: if isAuthenticated() &&
                       (
                         // Follower can update their own relationship.
                         (resource.data.followerId == request.auth.uid &&
                          request.resource.data.followerId == resource.data.followerId &&
                          request.resource.data.followingId == resource.data.followingId &&
                          relationshipId == resource.data.followerId + '_' + resource.data.followingId &&
                          request.resource.data.keys().hasAll(['followerId', 'followingId', 'status', 'createdAt']) &&
                          request.resource.data.status in ['PENDING', 'ACCEPTED', 'BLOCKED'] &&
                          !hasBlockRelationship(request.resource.data.followerId, request.resource.data.followingId)) ||
                         // Following user can accept a pending request.
                         (resource.data.followingId == request.auth.uid &&
                          resource.data.status == 'PENDING' &&
                          request.resource.data.followerId == resource.data.followerId &&
                          request.resource.data.followingId == resource.data.followingId &&
                          relationshipId == resource.data.followerId + '_' + resource.data.followingId &&
                          request.resource.data.keys().hasAll(['followerId', 'followingId', 'status', 'createdAt']) &&
                          request.resource.data.status == 'ACCEPTED')
                       );
                       
      // FIXED: Add explicit delete rule for unfollow operations
      // Allow deletion if user is either the follower or the one being followed
      allow delete: if isAuthenticated() &&
                       (resource.data.followerId == request.auth.uid ||
                        resource.data.followingId == request.auth.uid);
    }
    
    // Gym buddy relationships - inner circle connections
    match /gym_buddies/{buddyId} {
      allow read: if isAuthenticated() &&
                     (isOwner(resource.data.userId) ||
                      isOwner(resource.data.buddyId));
                      
      allow write: if isAuthenticated() &&
                      (isOwner(request.resource.data.userId) ||
                       isOwner(request.resource.data.buddyId)) &&
                      request.resource.data.keys().hasAll(['userId', 'buddyId', 'createdAt']) &&
                      request.resource.data.userId != request.resource.data.buddyId &&
                      !hasBlockRelationship(request.resource.data.userId, request.resource.data.buddyId);
                      
      allow create: if isAuthenticated() &&
                       (isOwner(request.resource.data.userId) ||
                        isOwner(request.resource.data.buddyId)) &&
                       request.resource.data.keys().hasAll(['userId', 'buddyId', 'createdAt']) &&
                       request.resource.data.userId != request.resource.data.buddyId &&
                       !hasBlockRelationship(request.resource.data.userId, request.resource.data.buddyId);
    }
    
    // Social privacy settings - user-specific privacy controls
    match /social_privacy_settings/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && 
                       isOwner(userId) &&
                       request.resource.data.userId == request.auth.uid;
    }
    
    // Blocked users - user blocking functionality
    match /blocked_users/{blockId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow write: if isAuthenticated() &&
                      isOwner(request.resource.data.userId) &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['userId', 'blockedUserId', 'blockedAt']) &&
                      request.resource.data.userId != request.resource.data.blockedUserId;
                      
      allow create: if isAuthenticated() &&
                       isOwner(request.resource.data.userId) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'blockedUserId', 'blockedAt']) &&
                       request.resource.data.userId != request.resource.data.blockedUserId;
    }
    
    // Shared workouts - workout sharing with privacy controls
    match /shared_workouts/{workoutId} {
      allow read: if isAuthenticated() &&
                     (!hasBlockRelationship(request.auth.uid, resource.data.userId) &&
                      (resource.data.visibility == 'PUBLIC' ||
                       (resource.data.visibility == 'FOLLOWERS' && isFollower(resource.data.userId)) ||
                       isOwner(resource.data.userId)));
                       
      allow write: if isAuthenticated() &&
                      isOwner(request.resource.data.userId) &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['userId', 'workoutData', 'visibility', 'createdAt']) &&
                      request.resource.data.visibility in ['PUBLIC', 'FOLLOWERS', 'PRIVATE'];
                      
      allow create: if isAuthenticated() &&
                       isOwner(request.resource.data.userId) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'workoutData', 'visibility', 'createdAt']) &&
                       request.resource.data.visibility in ['PUBLIC', 'FOLLOWERS', 'PRIVATE'];
    }
    
    // ========================================
    // AI CHAT SYSTEM SECURITY RULES
    // Added for chat preferences and chat history collections
    // ========================================
    
    // Helper functions for chat data validation
    function isValidChatPreferences() {
      return request.resource.data.keys().hasAll(['preferredLanguage', 'autoDetectLanguage', 'updatedAt']) &&
             request.resource.data.preferredLanguage is string &&
             request.resource.data.preferredLanguage in ['en', 'ro'] &&
             request.resource.data.autoDetectLanguage is bool &&
             request.resource.data.updatedAt is int &&
             // Allow optional fields that ChatSyncWorker writes
             (!('chatNotificationsEnabled' in request.resource.data) || request.resource.data.chatNotificationsEnabled is bool) &&
             (!('conversationHistoryEnabled' in request.resource.data) || request.resource.data.conversationHistoryEnabled is bool) &&
             (!('workoutContextSharing' in request.resource.data) || request.resource.data.workoutContextSharing is bool) &&
             (!('maxMessagesPerDay' in request.resource.data) || request.resource.data.maxMessagesPerDay is int) &&
             (!('maxTokensPerMonth' in request.resource.data) || request.resource.data.maxTokensPerMonth is int) &&
             (!('autoClearDays' in request.resource.data) || request.resource.data.autoClearDays is int) &&
             (!('userContextPrompt' in request.resource.data) || request.resource.data.userContextPrompt == null || request.resource.data.userContextPrompt is string) &&
             (!('syncVersion' in request.resource.data) || request.resource.data.syncVersion is int) &&
             (!('lastSyncedAt' in request.resource.data) || request.resource.data.lastSyncedAt is timestamp);
    }
    
    function isValidChatMessage() {
      return request.resource.data.keys().hasAll(['conversationId', 'messageType', 'language', 'content', 'createdAt']) &&
             request.resource.data.conversationId is string &&
             request.resource.data.messageType is string &&
             request.resource.data.messageType in ['USER', 'ASSISTANT', 'SYSTEM'] &&
             request.resource.data.language is string &&
             request.resource.data.language in ['en', 'ro'] &&
             request.resource.data.content is string &&
             request.resource.data.content.size() > 0 &&
             request.resource.data.content.size() <= 10000 &&
             request.resource.data.createdAt is int &&
             // Allow optional fields that ChatSyncWorker writes
             (!('workoutContext' in request.resource.data) || request.resource.data.workoutContext == null || request.resource.data.workoutContext is string) &&
             (!('tokenCount' in request.resource.data) || request.resource.data.tokenCount == null || request.resource.data.tokenCount is int) &&
             (!('processingTimeMs' in request.resource.data) || request.resource.data.processingTimeMs == null || request.resource.data.processingTimeMs is int) &&
             (!('syncVersion' in request.resource.data) || request.resource.data.syncVersion is int) &&
             (!('lastSyncedAt' in request.resource.data) || request.resource.data.lastSyncedAt is timestamp);
    }
    
    // Chat preferences - user-specific AI chat settings
    match /users/{userId}/chat_preferences/{docId} {
      allow read: if isAuthenticated() && isOwner(userId);
      
      allow write: if isAuthenticated() && 
                      isOwner(userId) && 
                      isValidChatPreferences();
      
      allow create: if isAuthenticated() && 
                       isOwner(userId) && 
                       isValidChatPreferences();
    }
    
    // Chat history - user conversation messages with AI
    match /users/{userId}/chat_history/{messageId} {
      allow read: if isAuthenticated() && isOwner(userId);
      
      allow write: if isAuthenticated() && 
                      isOwner(userId) && 
                      isValidChatMessage();
      
      allow create: if isAuthenticated() && 
                       isOwner(userId) && 
                       isValidChatMessage();
    }
    
    // User settings - preferences and configuration (root-level collection)
    // This is used by SettingsPersistenceManager for dark mode, notifications, weight units, etc.
    match /user_settings/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      
      allow write: if isAuthenticated() && 
                      isOwner(userId) &&
                      // Allow flexible updates for settings fields
                      (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid) &&
                      (!('dark_mode' in request.resource.data) || request.resource.data.dark_mode is bool) &&
                      (!('notification_enabled' in request.resource.data) || request.resource.data.notification_enabled is bool) &&
                      (!('notifications_enabled' in request.resource.data) || request.resource.data.notifications_enabled is bool) &&
                      (!('workout_reminders' in request.resource.data) || request.resource.data.workout_reminders is bool) &&
                      (!('pr_notifications' in request.resource.data) || request.resource.data.pr_notifications is bool) &&
                      (!('theme' in request.resource.data) || request.resource.data.theme is string) &&
                      (!('units' in request.resource.data) || request.resource.data.units is string) &&
                      (!('weight_unit' in request.resource.data) || request.resource.data.weight_unit is string) &&
                      (!('rest_timer_enabled' in request.resource.data) || request.resource.data.rest_timer_enabled is bool) &&
                      (!('rest_timer_default_seconds' in request.resource.data) || request.resource.data.rest_timer_default_seconds is int) &&
                      (!('auto_start_rest_timer' in request.resource.data) || request.resource.data.auto_start_rest_timer is bool) &&
                      (!('terminology_preference' in request.resource.data) || request.resource.data.terminology_preference is string) &&
                      (!('migration_completed' in request.resource.data) || request.resource.data.migration_completed is bool) &&
                      (!('migration_explanation_seen' in request.resource.data) || request.resource.data.migration_explanation_seen is bool) &&
                      (!('last_updated' in request.resource.data) || request.resource.data.last_updated is number) &&
                      (!('created_at' in request.resource.data) || request.resource.data.created_at is timestamp) &&
                      (!('updated_at' in request.resource.data) || request.resource.data.updated_at is timestamp) &&
                      (!('settings_version' in request.resource.data) || request.resource.data.settings_version is number);
      
      allow create: if isAuthenticated() && 
                       isOwner(userId) &&
                       // Allow flexible creation with any combination of settings fields including required fields from profile creation
                       (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid) &&
                       (!('dark_mode' in request.resource.data) || request.resource.data.dark_mode is bool) &&
                       (!('notification_enabled' in request.resource.data) || request.resource.data.notification_enabled is bool) &&
                       (!('notifications_enabled' in request.resource.data) || request.resource.data.notifications_enabled is bool) &&
                       (!('workout_reminders' in request.resource.data) || request.resource.data.workout_reminders is bool) &&
                       (!('pr_notifications' in request.resource.data) || request.resource.data.pr_notifications is bool) &&
                       (!('theme' in request.resource.data) || request.resource.data.theme is string) &&
                       (!('units' in request.resource.data) || request.resource.data.units is string) &&
                       (!('weight_unit' in request.resource.data) || request.resource.data.weight_unit is string) &&
                       (!('rest_timer_enabled' in request.resource.data) || request.resource.data.rest_timer_enabled is bool) &&
                       (!('rest_timer_default_seconds' in request.resource.data) || request.resource.data.rest_timer_default_seconds is int) &&
                       (!('auto_start_rest_timer' in request.resource.data) || request.resource.data.auto_start_rest_timer is bool) &&
                       (!('terminology_preference' in request.resource.data) || request.resource.data.terminology_preference is string) &&
                       (!('migration_completed' in request.resource.data) || request.resource.data.migration_completed is bool) &&
                       (!('migration_explanation_seen' in request.resource.data) || request.resource.data.migration_explanation_seen is bool) &&
                       (!('last_updated' in request.resource.data) || request.resource.data.last_updated is number) &&
                       (!('created_at' in request.resource.data) || request.resource.data.created_at is timestamp) &&
                       (!('updated_at' in request.resource.data) || request.resource.data.updated_at is timestamp) &&
                       (!('settings_version' in request.resource.data) || request.resource.data.settings_version is number);
    }
    
    // User settings - preferences and configuration (subcollection for backward compatibility)
    match /users/{userId}/settings/{docId} {
      allow read: if isAuthenticated() && isOwner(userId);
      
      allow write: if isAuthenticated() && 
                      isOwner(userId) && 
                      request.resource.data.keys().hasAll(['userId']) &&
                      request.resource.data.userId == request.auth.uid;
      
      allow create: if isAuthenticated() && 
                       isOwner(userId) && 
                       request.resource.data.keys().hasAll(['userId']) &&
                       request.resource.data.userId == request.auth.uid;
    }
    
    // Gym buddies - mutual fitness connections
    match /users/{userId}/gym_buddies/{buddyId} {
      allow read: if isAuthenticated() && isOwner(userId);
      
      allow write: if isAuthenticated() && 
                      isOwner(userId) &&
                      request.resource.data.keys().hasAll(['buddyId']) &&
                      request.resource.data.buddyId is string;
      
      allow create: if isAuthenticated() && 
                       isOwner(userId) &&
                       request.resource.data.keys().hasAll(['buddyId']) &&
                       request.resource.data.buddyId is string;
    }
    
    // Workout posts - social feed posts
    match /workout_posts/{postId} {
      allow read: if isAuthenticated() &&
                     (!hasBlockRelationship(request.auth.uid, resource.data.userId) &&
                      (resource.data.visibility == 'PUBLIC' ||
                       (resource.data.visibility == 'FOLLOWERS' && isFollower(resource.data.userId)) ||
                       isOwner(resource.data.userId)));
                       
      allow write: if isAuthenticated() &&
                      isOwner(request.resource.data.userId) &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['userId', 'workoutId', 'visibility', 'createdAt']) &&
                      request.resource.data.visibility in ['PUBLIC', 'FOLLOWERS', 'PRIVATE'];
                      
      allow create: if isAuthenticated() &&
                       isOwner(request.resource.data.userId) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'workoutId', 'visibility', 'createdAt']) &&
                       request.resource.data.visibility in ['PUBLIC', 'FOLLOWERS', 'PRIVATE'];
    }
    
    // Analytics data - user analytics and metrics
    match /analytics/{docId} {
      allow read: if isAuthenticated() && 
                     docId.matches('^' + request.auth.uid + '_.*');
      
      allow write: if isAuthenticated() && 
                      request.resource.data.keys().hasAll(['userId', 'calculationType']) &&
                      request.resource.data.userId == request.auth.uid &&
                      docId.matches('^' + request.auth.uid + '_.*');
      
      allow create: if isAuthenticated() && 
                       request.resource.data.keys().hasAll(['userId', 'calculationType']) &&
                       request.resource.data.userId == request.auth.uid &&
                       docId.matches('^' + request.auth.uid + '_.*');
    }

    // ========================================
    // REAL-TIME SYNC INFRASTRUCTURE RULES
    // Added for workout sessions and personal records
    // ========================================
    
    // Workout sessions - real-time workout tracking
    // ARCHITECTURAL FIX: Using subcollections for proper user scoping
    match /users/{userId}/workout_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && 
                           isOwner(userId) &&
                           request.resource.data.keys().hasAll(['userId', 'status', 'lastModified']) &&
                           request.resource.data.status in ['ACTIVE', 'PAUSED', 'COMPLETED', 'CANCELLED'];
      
      allow create: if isAuthenticated() && 
                       isOwner(userId) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'status', 'lastModified']) &&
                       request.resource.data.status in ['ACTIVE', 'PAUSED', 'COMPLETED', 'CANCELLED'];
    }
    
    // Workout sessions subcollection - properly nested under user documents
    // Migrated from legacy top-level collection for better data organization
    match /users/{userId}/workout_sessions/{sessionId} {
      // Read: Allow if user owns the parent document
      allow read: if isAuthenticated() && isOwner(userId);
      
      // Write: Validate session structure and ownership
      allow write: if isAuthenticated() && 
                      isOwner(userId) &&
                      request.resource.data.keys().hasAll(['status', 'lastModified']) &&
                      request.resource.data.status in ['ACTIVE', 'PAUSED', 'COMPLETED', 'CANCELLED'];
      
      // Create: Ensure proper session creation with ownership validation
      allow create: if isAuthenticated() && 
                       isOwner(userId) &&
                       request.resource.data.keys().hasAll(['status', 'lastModified']) &&
                       request.resource.data.status in ['ACTIVE', 'PAUSED', 'COMPLETED', 'CANCELLED'];
    }
    
    // Personal records - real-time PR tracking and achievements
    match /personal_records/{recordId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      
      allow write: if isAuthenticated() && 
                      isOwner(request.resource.data.userId) &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['userId', 'exerciseId', 'recordType', 'achievedAt']) &&
                      request.resource.data.recordType in ['ONE_RM', 'VOLUME', 'REPS', 'MAX_WEIGHT'];
      
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'exerciseId', 'recordType', 'achievedAt']) &&
                       request.resource.data.recordType in ['ONE_RM', 'VOLUME', 'REPS', 'MAX_WEIGHT'];
    }
    
    // User presence - real-time status tracking for gym buddy system
    match /user_presence/{userId} {
      allow read: if isAuthenticated() && 
                     (isOwner(userId) || 
                      exists(/databases/$(database)/documents/gym_buddies/$(request.auth.uid + '_' + userId)) ||
                      exists(/databases/$(database)/documents/gym_buddies/$(userId + '_' + request.auth.uid)));
      
      allow write: if isAuthenticated() && 
                      isOwner(userId) &&
                      request.resource.data.keys().hasAll(['user_id', 'status', 'last_active']) &&
                      request.resource.data.user_id == request.auth.uid &&
                      request.resource.data.status in ['ONLINE', 'OFFLINE', 'WORKING_OUT'];
      
      allow create: if isAuthenticated() && 
                       isOwner(userId) &&
                       request.resource.data.keys().hasAll(['user_id', 'status', 'last_active']) &&
                       request.resource.data.user_id == request.auth.uid &&
                       request.resource.data.status in ['ONLINE', 'OFFLINE', 'WORKING_OUT'];
    }
    
    // Subscriptions - user subscription data created during profile creation
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && 
                     resource.data.user_id == request.auth.uid;
      
      allow write: if isAuthenticated() && 
                      request.resource.data.user_id == request.auth.uid &&
                      request.resource.data.keys().hasAll(['user_id']) &&
                      // Allow subscription fields created during profile creation
                      (!('tier' in request.resource.data) || request.resource.data.tier is string) &&
                      (!('status' in request.resource.data) || request.resource.data.status is string) &&
                      (!('provider' in request.resource.data) || request.resource.data.provider is string) &&
                      (!('started_at' in request.resource.data) || request.resource.data.started_at is timestamp) &&
                      (!('auto_renew' in request.resource.data) || request.resource.data.auto_renew is bool) &&
                      (!('features' in request.resource.data) || request.resource.data.features is list) &&
                      (!('metadata' in request.resource.data) || request.resource.data.metadata is map) &&
                      (!('claims_updated' in request.resource.data) || request.resource.data.claims_updated is bool) &&
                      (!('created_at' in request.resource.data) || request.resource.data.created_at is timestamp) &&
                      (!('version' in request.resource.data) || request.resource.data.version is int);
      
      allow create: if isAuthenticated() && 
                       request.resource.data.user_id == request.auth.uid &&
                       request.resource.data.keys().hasAll(['user_id']) &&
                       // Allow subscription fields created during profile creation
                       (!('tier' in request.resource.data) || request.resource.data.tier is string) &&
                       (!('status' in request.resource.data) || request.resource.data.status is string) &&
                       (!('provider' in request.resource.data) || request.resource.data.provider is string) &&
                       (!('started_at' in request.resource.data) || request.resource.data.started_at is timestamp) &&
                       (!('auto_renew' in request.resource.data) || request.resource.data.auto_renew is bool) &&
                       (!('features' in request.resource.data) || request.resource.data.features is list) &&
                       (!('metadata' in request.resource.data) || request.resource.data.metadata is map) &&
                       (!('claims_updated' in request.resource.data) || request.resource.data.claims_updated is bool) &&
                       (!('created_at' in request.resource.data) || request.resource.data.created_at is timestamp) &&
                       (!('version' in request.resource.data) || request.resource.data.version is int);
    }
    
    // ========================================
    // AUDIT LOGGING INFRASTRUCTURE (SEC-T005)
    // Tamper-evident write-only audit logs
    // ========================================

    // Audit logs - write-only collection for forensic analysis
    match /audit_logs/{logId} {
      // SECURITY: Read only for admin users (requires custom claims)
      // Regular users cannot read or modify audit logs
      allow read: if request.auth.token.admin == true;

      // SECURITY: Write-only for authenticated users
      // Logs can be created but never updated or deleted (tamper-evident)
      allow create: if isAuthenticated() &&
                       request.resource.data.keys().hasAll(['eventType', 'userId', 'timestamp']) &&
                       request.resource.data.eventType in [
                         'CONFLICT_RESOLUTION',
                         'HMAC_VERIFICATION_FAILURE',
                         'TIMESTAMP_MANIPULATION',
                         'USER_SCOPING_VIOLATION',
                         'DATA_TAMPERING'
                       ];

      // SECURITY: Prevent updates and deletes (tamper-evident)
      allow update, delete: if false;
    }

    // ========================================
    // GDPR COMPLIANCE & MODERATION RULES
    // Added for Google Play compliance (SPEC-20251230)
    // ========================================

    // User consent tracking - GDPR consent collection
    match /user_consents/{userId} {
      // Users can read their own consent records
      allow read: if isAuthenticated() && isOwner(userId);

      // Users can create/update their own consent records
      allow write, create: if isAuthenticated() &&
                              isOwner(userId) &&
                              request.resource.data.keys().hasAll(['userId', 'privacyPolicy', 'healthData', 'aiChat']) &&
                              request.resource.data.userId == request.auth.uid &&
                              request.resource.data.privacyPolicy is bool &&
                              request.resource.data.healthData is bool &&
                              request.resource.data.aiChat is bool &&
                              (!('analytics' in request.resource.data) || request.resource.data.analytics is bool) &&
                              (!('marketing' in request.resource.data) || request.resource.data.marketing is bool) &&
                              (!('consentVersion' in request.resource.data) || request.resource.data.consentVersion is string) &&
                              (!('acceptedAt' in request.resource.data) || request.resource.data.acceptedAt is int);
    }

    // Moderation actions - admin-only audit trail for moderation
    match /moderation_actions/{actionId} {
      // Only admins can read moderation actions
      allow read: if request.auth.token.admin == true;

      // Only admins can create moderation action records (tamper-evident)
      allow create: if request.auth.token.admin == true &&
                       request.resource.data.keys().hasAll(['admin_user_id', 'action_type', 'target_type', 'target_id', 'reason']) &&
                       request.resource.data.admin_user_id == request.auth.uid &&
                       request.resource.data.action_type is string &&
                       request.resource.data.target_type is string &&
                       request.resource.data.target_id is string &&
                       request.resource.data.reason is string;

      // Prevent updates and deletes (tamper-evident audit log)
      allow update, delete: if false;
    }

    // Content reports - user reporting of inappropriate content
    match /content_reports/{reportId} {
      // Users can only read their own reports, admins can read all
      allow read: if isAuthenticated() &&
                     (request.auth.token.admin == true ||
                      resource.data.reporter_user_id == request.auth.uid);

      // Any authenticated user can create a content report
      allow create: if isAuthenticated() &&
                       request.resource.data.keys().hasAll(['reporter_user_id', 'content_type', 'content_id', 'reason']) &&
                       request.resource.data.reporter_user_id == request.auth.uid &&
                       request.resource.data.content_type in ['POST', 'COMMENT', 'PROFILE'] &&
                       request.resource.data.content_id is string &&
                       request.resource.data.reason in ['SPAM', 'HARASSMENT', 'HATE_SPEECH', 'INAPPROPRIATE', 'MISINFORMATION', 'OTHER'] &&
                       (!('notes' in request.resource.data) || request.resource.data.notes is string) &&
                       (!('status' in request.resource.data) || request.resource.data.status == 'PENDING');

      // Only admins can update reports (for status changes)
      allow update: if request.auth.token.admin == true;

      // Prevent report deletion
      allow delete: if false;
    }

    // AI reports - user reporting of AI-generated harmful content
    match /ai_reports/{reportId} {
      // Users can only read their own reports, admins can read all
      allow read: if isAuthenticated() &&
                     (request.auth.token.admin == true ||
                      resource.data.reporter_user_id == request.auth.uid);

      // Any authenticated user can create an AI report
      allow create: if isAuthenticated() &&
                       request.resource.data.keys().hasAll(['message_id', 'message_content', 'reason', 'reporter_user_id']) &&
                       request.resource.data.message_id is string &&
                       request.resource.data.message_content is string &&
                       request.resource.data.reason is string &&
                       request.resource.data.reporter_user_id == request.auth.uid &&
                       (!('notes' in request.resource.data) || request.resource.data.notes is string) &&
                       (!('status' in request.resource.data) || request.resource.data.status == 'PENDING');

      // Only admins can update reports (for status changes)
      allow update: if request.auth.token.admin == true;

      // Prevent report deletion
      allow delete: if false;
    }

    // Account restrictions - admin-imposed restrictions on user accounts
    match /account_restrictions/{restrictionId} {
      // Users can read their own restrictions, admins can read all
      allow read: if isAuthenticated() &&
                     (request.auth.token.admin == true ||
                      resource.data.user_id == request.auth.uid);

      // Only admins can create/update account restrictions
      allow write: if request.auth.token.admin == true &&
                      request.resource.data.keys().hasAll(['user_id', 'restriction_type', 'reason', 'start_time']) &&
                      request.resource.data.user_id is string &&
                      request.resource.data.restriction_type in ['WARNED', 'SUSPENDED', 'BANNED'] &&
                      request.resource.data.reason is string &&
                      request.resource.data.start_time is int &&
                      (!('end_time' in request.resource.data) || request.resource.data.end_time == null || request.resource.data.end_time is int) &&
                      (!('is_active' in request.resource.data) || request.resource.data.is_active is bool);

      allow create: if request.auth.token.admin == true &&
                       request.resource.data.keys().hasAll(['user_id', 'restriction_type', 'reason', 'start_time']) &&
                       request.resource.data.user_id is string &&
                       request.resource.data.restriction_type in ['WARNED', 'SUSPENDED', 'BANNED'] &&
                       request.resource.data.reason is string &&
                       request.resource.data.start_time is int &&
                       (!('end_time' in request.resource.data) || request.resource.data.end_time == null || request.resource.data.end_time is int) &&
                       (!('is_active' in request.resource.data) || request.resource.data.is_active is bool);

      // Prevent deletion (audit trail)
      allow delete: if false;
    }

    // Account deletion queue - GDPR-compliant account deletion tracking
    match /deletion_queue/{userId} {
      // Users can only read their own deletion requests, admins can read all
      allow read: if isAuthenticated() &&
                     (request.auth.token.admin == true || isOwner(userId));

      // Users can create their own deletion request
      allow create: if isAuthenticated() &&
                       isOwner(userId) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'requestedAt']) &&
                       request.resource.data.requestedAt is int;

      // Only Cloud Functions can update/delete (processed by processAccountDeletion function)
      allow update, delete: if false;
    }

    // Post comments - user comments on workout posts with moderation support
    match /post_comments/{commentId} {
      // Users can read comments on posts they can access
      allow read: if isAuthenticated() &&
                     !hasBlockRelationship(request.auth.uid, resource.data.userId);

      // Users can create/update their own comments
      allow write: if isAuthenticated() &&
                      isOwner(request.resource.data.userId) &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['postId', 'userId', 'content', 'createdAt']) &&
                      request.resource.data.postId is string &&
                      request.resource.data.content is string &&
                      request.resource.data.content.size() > 0 &&
                      request.resource.data.content.size() <= 500 &&
                      request.resource.data.createdAt is int;

      allow create: if isAuthenticated() &&
                       isOwner(request.resource.data.userId) &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['postId', 'userId', 'content', 'createdAt']) &&
                       request.resource.data.postId is string &&
                       request.resource.data.content is string &&
                       request.resource.data.content.size() > 0 &&
                       request.resource.data.content.size() <= 500 &&
                       request.resource.data.createdAt is int;

      // Users can delete their own comments, admins can delete any
      allow delete: if isAuthenticated() &&
                       (request.auth.token.admin == true ||
                        resource.data.userId == request.auth.uid);
    }

    // Default deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

/* 
DEPLOYMENT INSTRUCTIONS:

1. Firebase Console Setup:
   - Go to https://console.firebase.google.com
   - Select your Liftrix project
   - Navigate to Firestore Database -> Rules

2. Copy and paste the above rules into the Firebase Console

3. Test the rules using the Firebase Console simulator with:
   - auth.uid = "test-user-123"
   - Test reading/writing users_public documents
   - Test privacy controls (isPublic field)

4. Required Firestore Indexes:
   Create these composite indexes in Firebase Console:

   Collection: users_public
   Fields: isPublic (Ascending), displayName (Ascending)
   
   Collection: user_search_cache  
   Fields: isPublic (Ascending), displayName (Ascending), lastActiveAt (Descending)
   
   Collection: qr_codes
   Fields: userId (Ascending), expiresAt (Ascending)
   
   // Firebase Sync Infrastructure Indexes (added by SPEC-20250118-firebase-sync-infrastructure)
   Collection: users
   Fields: userId (Ascending), lastModified (Descending)
   
   Collection Group: workouts (users/{userId}/workouts/{workoutId})
   Fields: userId (Ascending), status (Ascending), date (Descending)
   
   Collection Group: workouts (users/{userId}/workouts/{workoutId})
   Fields: userId (Ascending), lastModified (Descending)
   
   Collection Group: templates (users/{userId}/templates/{templateId})
   Fields: userId (Ascending), isPublic (Ascending), lastModified (Descending)
   
   Collection Group: templates (users/{userId}/templates/{templateId})
   Fields: userId (Ascending), tags (Array), lastModified (Descending)
   
   Collection Group: achievements (users/{userId}/achievements/{achievementId})
   Fields: userId (Ascending), type (Ascending), unlockedAt (Descending)
   
   Collection Group: achievements (users/{userId}/achievements/{achievementId})
   Fields: userId (Ascending), unlockedAt (Descending)
   
   // Social Infrastructure Indexes (added by SPEC-20250113-social-infrastructure)
   Collection: social_profiles
   Fields: username (Ascending)
   
   Collection: social_profiles  
   Fields: isPrivate (Ascending), memberSince (Descending)
   
   Collection: follow_relationships
   Fields: followerId (Ascending), status (Ascending)
   
   Collection: follow_relationships
   Fields: followingId (Ascending), status (Ascending)
   
   Collection: blocked_users
   Fields: userId (Ascending), blockedAt (Descending)
   
   Collection: shared_workouts
   Fields: userId (Ascending), visibility (Ascending), createdAt (Descending)
   
   // Real-time Sync Infrastructure Indexes (added for workout sessions and presence)
   Collection: workout_sessions
   Fields: userId (Ascending), status (Ascending), lastModified (Descending)
   
   Collection: personal_records
   Fields: userId (Ascending), recordType (Ascending), achievedAt (Descending)
   
   Collection: personal_records
   Fields: userId (Ascending), achievedAt (Descending)
   
   Collection: user_presence
   Fields: user_id (Ascending), status (Ascending), last_active (Descending)
   
   // AI Chat System Indexes (added for chat preferences and history)
   Collection Group: chat_preferences (users/{userId}/chat_preferences/{docId})
   Fields: userId (Ascending), updatedAt (Descending)
   
   Collection Group: chat_history (users/{userId}/chat_history/{messageId})
   Fields: userId (Ascending), conversationId (Ascending), createdAt (Descending)
   
   Collection Group: chat_history (users/{userId}/chat_history/{messageId})
   Fields: userId (Ascending), messageType (Ascending), createdAt (Descending)
   
   Collection Group: chat_history (users/{userId}/chat_history/{messageId})
   Fields: userId (Ascending), createdAt (Descending)
   
   // Additional Sync Worker Indexes (added for comprehensive sync support)
   Collection: workout_posts
   Fields: userId (Ascending), visibility (Ascending), createdAt (Descending)
   
   Collection: workout_posts
   Fields: userId (Ascending), createdAt (Descending)
   
   Collection: analytics
   Fields: userId (Ascending), calculationType (Ascending), timestamp (Descending)
   
   Collection Group: settings (users/{userId}/settings/{docId})
   Fields: userId (Ascending), updatedAt (Descending)
   
   Collection Group: gym_buddies (users/{userId}/gym_buddies/{buddyId})
   Fields: userId (Ascending), createdAt (Descending)

5. Verify deployment by testing:
   - Profile creation and updates
   - Privacy setting changes
   - User search functionality
   - QR code generation and lookup
   - Social profile creation and retrieval
   - Follow relationship management
   - Gym buddy pairing
   - User blocking functionality
   - Shared workout visibility controls
   - Sync infrastructure data operations:
     * User profile sync (create/read/update with sync metadata)
     * Workout data sync (CRUD operations with user scoping)
     * Template sharing (public template visibility)
     * Achievement creation (server-side only)
     * Offline queue processing
   - Real-time sync operations:
     * Workout session tracking (ACTIVE/PAUSED/COMPLETED status)
     * Personal record listener (PR detection and achievements)
     * Presence tracking (online/offline/working out status)
   - AI Chat system operations:
     * Chat preferences sync and validation
     * Chat history persistence with proper user scoping
     * Message type validation (USER/ASSISTANT/SYSTEM)
     * Token usage tracking and limits enforcement
*/
